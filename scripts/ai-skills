#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATE_DIR="$ROOT_DIR/templates/skills"

usage() {
  cat <<'EOF'
ai-skills - install shared skills for AI CLIs

Usage:
  ai-skills list
  ai-skills install <codex|claude|gemini> <skill>
  ai-skills sync [skill]

Locations:
  Codex  -> ${CODEX_HOME:-~/.codex}/skills/<skill>
  Claude -> ~/.claude/skills/<skill>
  Gemini -> gemini extensions install <template>, fallback ~/.gemini/extensions/<skill>
EOF
}

copy_dir() {
  local src="$1" dst="$2"
  [[ -d "$src" ]] || { echo "Missing template: $src" >&2; return 1; }
  mkdir -p "$(dirname "$dst")"
  rm -rf "$dst"
  cp -a "$src" "$dst"
  echo "Installed: $dst"
}

list_skills() {
  find "$TEMPLATE_DIR/codex" -mindepth 1 -maxdepth 1 -type d -print 2>/dev/null |
    xargs -n 1 basename 2>/dev/null | sort
}

install_codex() {
  local skill="$1"
  local codex_home="${CODEX_HOME:-$HOME/.codex}"
  copy_dir "$TEMPLATE_DIR/codex/$skill" "$codex_home/skills/$skill"
}

install_claude() {
  local skill="$1"
  copy_dir "$TEMPLATE_DIR/claude/$skill" "$HOME/.claude/skills/$skill"
}

install_gemini() {
  local skill="$1"
  local src="$TEMPLATE_DIR/gemini/$skill"
  [[ -d "$src" ]] || { echo "Missing template: $src" >&2; return 1; }
  if command -v gemini >/dev/null 2>&1; then
    gemini extensions install "$src"
  else
    copy_dir "$src" "$HOME/.gemini/extensions/$skill"
  fi
}

install_one() {
  local target="${1:-}" skill="${2:-}"
  [[ -n "$target" && -n "$skill" ]] || { usage >&2; return 1; }
  case "$target" in
    codex) install_codex "$skill" ;;
    claude) install_claude "$skill" ;;
    gemini) install_gemini "$skill" ;;
    *) usage >&2; return 1 ;;
  esac
}

sync_skill() {
  local skill="$1"
  install_codex "$skill"
  install_claude "$skill"
  install_gemini "$skill"
}

sync_all() {
  local skill
  while IFS= read -r skill; do
    [[ -n "$skill" ]] && sync_skill "$skill"
  done < <(list_skills)
}

case "${1:-}" in
  list) list_skills ;;
  install) shift; install_one "$@" ;;
  sync)
    shift
    if [[ -n "${1:-}" ]]; then sync_skill "$1"; else sync_all; fi
    ;;
  -h|--help|help|"") usage ;;
  *) usage >&2; exit 1 ;;
esac
