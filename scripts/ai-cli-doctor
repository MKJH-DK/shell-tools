#!/usr/bin/env bash
set -Eeuo pipefail

have() { command -v "$1" >/dev/null 2>&1; }

version_of() {
  "$1" --version 2>/dev/null | head -n 1 || true
}

check_binary() {
  local binary="$1" label="$2"
  if have "$binary"; then
    printf '[ok]   %-10s %s %s\n' "$label" "$(command -v "$binary")" "$(version_of "$binary")"
  else
    printf '[miss] %-10s not found\n' "$label"
  fi
}

check_env() {
  local name="$1"
  if [[ -n "${!name:-}" ]]; then
    printf '[ok]   %-22s set\n' "$name"
  else
    printf '[miss] %-22s missing\n' "$name"
  fi
}

check_alias() {
  local shell_file="${XDG_CONFIG_HOME:-$HOME/.config}/zsh/conf.d/00-base.zsh"
  local alias_name="$1"
  if [[ -f "$shell_file" ]] && grep -qE "alias[[:space:]]+$alias_name=" "$shell_file"; then
    printf '[ok]   alias %-10s configured\n' "$alias_name"
  else
    printf '[info] alias %-10s not configured in generated zsh base\n' "$alias_name"
  fi
}

echo "AI CLI Doctor"
echo
echo "Tools"
check_binary codex "codex"
check_binary gemini "gemini"
check_binary claude "claude"
check_binary sgpt "sgpt"
check_binary ask "ask"
echo
echo "Runtime"
check_binary node "node"
check_binary npm "npm"
check_binary python3 "python3"
check_binary pipx "pipx"
echo
echo "Environment names only"
check_env OPENAI_API_KEY
check_env ANTHROPIC_API_KEY
check_env GOOGLE_API_KEY
check_env GEMINI_API_KEY
check_env OPENROUTER_API_KEY
check_env GROQ_API_KEY
check_env OLLAMA_BASE_URL
echo
echo "Aliases"
check_alias cx
check_alias gm
check_alias cl
check_alias ask
check_alias ai-status
check_alias ai-install
